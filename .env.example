APP_NAME=distributed-url-shortener
LOG_LEVEL=INFO
ENVIRONMENT=local

DATABASE_URL=postgresql://shortuser:shortpass@localhost:5432/shortdb
REDIS_URL=redis://localhost:6379/0

BASE_URL=http://localhost:8000
SHORT_CODE_LENGTH=7
CACHE_TTL_SECONDS=3600
CACHE_KEY_PREFIX=url:cache:

REDIS_CLICK_QUEUE_KEY=clicks:queue
WORKER_POLL_TIMEOUT=5
WORKER_MAX_RETRIES=3
WORKER_BASE_BACKOFF_SECONDS=1.0

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

IP_HASH_SALT=change-me-in-production
